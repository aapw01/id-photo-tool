# Pixfit · environment variables
# Copy to .env.local for local overrides. All NEXT_PUBLIC_* values are
# inlined at build time, so they need to be set wherever you build, not
# just at runtime.

# --- Segmentation runtime ---

# onnxruntime-web WASM / .mjs asset host. Defaults to the pinned jsDelivr
# version (see src/features/segmentation/runtime-config.ts).
#   Production (after R2 hookup): https://cdn.pix-fit.com/ort/1.26.0/
# NEXT_PUBLIC_ORT_BASE_URL=https://cdn.jsdelivr.net/npm/onnxruntime-web@1.26.0/dist/

# MODNet ONNX model URL. Defaults to /_models/modnet.q.onnx, which is
# served as a Next.js static asset. After Cloudflare R2 is wired up:
#   NEXT_PUBLIC_MODEL_URL=https://cdn.pix-fit.com/models/modnet.q.onnx
# NEXT_PUBLIC_MODEL_URL=/_models/modnet.q.onnx
